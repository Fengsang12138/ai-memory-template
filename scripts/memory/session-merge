#!/usr/bin/env sh
set -eu
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
. "$SCRIPT_DIR/common.sh"
ensure_files

CACHE_FILE="$MEM_DIR/.session-cache.md"
KEEP="false"
PROMOTE="false"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --cache) CACHE_FILE="${2-}"; shift 2;;
    --keep) KEEP="true"; shift;;
    --promote) PROMOTE="true"; shift;;
    *) echo "Unknown arg: $1" >&2; exit 1;;
  esac
done

if [ "$PROMOTE" != "true" ]; then
  echo "Session cache is not promoted by default. Re-run with --promote to append it to $MEM_DIR/progress.md."
  exit 0
fi

if [ ! -f "$CACHE_FILE" ] || [ ! -s "$CACHE_FILE" ]; then
  echo "No cached session logs to merge."
  exit 0
fi

cat "$CACHE_FILE" >> "$MEM_DIR/progress.md"

if [ "$KEEP" != "true" ]; then
  : > "$CACHE_FILE"
fi

"$SCRIPT_DIR/brief-refresh" >/dev/null 2>&1 || true
echo "Merged session cache into $MEM_DIR/progress.md (+ refreshed brief.md)"
