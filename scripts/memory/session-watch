#!/usr/bin/env sh
set -eu
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
. "$SCRIPT_DIR/common.sh"
ensure_files

INTERVAL=300
SUMMARY="自动捕获（未摘要）"
SESSION_ROOT="${CODEX_SESSION_DIR:-$HOME/.codex/sessions}"
CACHE_FILE="$MEM_DIR/.session-cache.md"
STATE_FILE="$MEM_DIR/.session-watch.state"
ONCE="false"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --interval) INTERVAL="${2-}"; shift 2;;
    --summary) SUMMARY="${2-}"; shift 2;;
    --session-dir) SESSION_ROOT="${2-}"; shift 2;;
    --cache) CACHE_FILE="${2-}"; shift 2;;
    --state) STATE_FILE="${2-}"; shift 2;;
    --once) ONCE="true"; shift;;
    *) echo "Unknown arg: $1" >&2; exit 1;;
  esac
done

if [ -z "$SUMMARY" ]; then
  SUMMARY="自动捕获（未摘要）"
fi

latest_session() {
  if [ ! -d "$SESSION_ROOT" ]; then
    return 0
  fi
  find "$SESSION_ROOT" -type f -name "*.jsonl" -print0 | xargs -0 ls -1t 2>/dev/null | head -n1 || true
}

while true; do
  latest="$(latest_session)"
  if [ -n "$latest" ]; then
    last=""
    if [ -f "$STATE_FILE" ]; then
      last="$(cat "$STATE_FILE" 2>/dev/null || true)"
    fi
    if [ "$latest" != "$last" ]; then
      "$SCRIPT_DIR/session-cache" --session "$latest" --cache "$CACHE_FILE" --summary "$SUMMARY"
      echo "$latest" > "$STATE_FILE"
    fi
  fi

  if [ "$ONCE" = "true" ]; then
    break
  fi
  sleep "$INTERVAL"
done
